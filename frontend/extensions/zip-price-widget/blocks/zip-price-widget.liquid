<div class="zip-pricing-container" style="margin-top:15px;">

  <label for="zipCode">
    Enter ZIP Code
  </label>

  <br><br>

  <input
    type="text"
    id="zipCode"
    placeholder="Enter ZIP Code"
    style="padding:10px; width:200px;">

  <button
    id="checkPriceBtn"
    style="padding:10px 15px; margin-left:10px;">
    Check Price
  </button>

  <div
    id="priceResult"
    style="margin-top:15px; font-weight:bold;">
  </div>

</div>

<script src="{{ 'zip-price.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "ZIP Price Widget",
  "target": "section",
  "settings": []
}
{% endschema %}